{
  "manifest_version": 3,
  "name": "IO HELPER",
  "version": "2.3",
  "description": "Optimizing the Moderation Interface",
  "permissions": [ "storage", "activeTab" ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [ "*://*.cybershoke.net/*" ],
      "css": [ "content.css" ],
      "js": [
        "rules.js",
        "modules/ModerHLPRUtils.js",
        "modules/ModerHLPRBadgeService.js",
        "modules/ModerHLPRPanelService.js",
        "modules/ModerHLPRMessageService.js",
        "modules/TicketRuleIcons.js",
        "modules/ModerHLPRTicketService.js",
        "modules/ModerHLPRModeratorService.js",
        "modules/ModerHLPRApp.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}