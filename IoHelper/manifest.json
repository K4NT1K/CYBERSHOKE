{
  "manifest_version": 3,
  "name": "IO HELPER",
  "version": "2.3.1",
  "description": "Улучшает функционал IO сайта",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "host_permissions": [
    "https://raw.githubusercontent.com/K4NT1K/*",
    "https://steamid.io/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icons.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.cybershoke.net/*"
      ],
      "css": [
        "css/panel.css",
        "css/analysis.css",
        "css/tooltip.css",
        "css/highlight.css",
        "css/misc.css"
      ],
      "js": [
        "modules/Utils.js",
        "modules/ConfigService.js",
        "modules/BadgeService.js",
        "modules/PanelService.js",
        "modules/MessageService.js",
        "modules/TicketService.js",
        "modules/ModeratorService.js",
        "modules/App.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
