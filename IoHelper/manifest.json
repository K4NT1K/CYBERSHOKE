{
  "manifest_version": 3,
  "name": "IO HELPER",
  "version": "2.2.1",
  "description": "Улучшает функционал IO сайта",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "host_permissions": [
    "https://raw.githubusercontent.com/K4NT1K/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.cybershoke.net/*"
      ],
      "css": [
        "css/panel.css",
        "css/analysis.css",
        "css/tooltip.css",
        "css/highlight.css",
        "css/misc.css"
      ],
      "js": [
        "modules/Utils.js",
        "modules/ConfigService.js",
        "modules/BadgeService.js",
        "modules/PanelService.js",
        "modules/MessageService.js",
        "modules/TicketRuleIcons.js",
        "modules/TicketService.js",
        "modules/ModeratorService.js",
        "modules/App.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}